<div class="col-md-4 mb-4">
    <div class="card h-100 shadow-sm border-0 product-card">
        <div class="product-image-container position-relative">
            <img src="{{ product.image }}" class="card-img-top" alt="{{ product.title }}" loading="lazy" style="height: 200px; object-fit: cover;">
            <div class="price-badge position-absolute top-0 end-0 bg-primary text-white p-2 m-2 rounded shadow-sm">
                {{ product.price|number_format(2, ',', '.') }} €
            </div>
        </div>
        <div class="card-body">
            <h5 class="card-title text-truncate">{{ product.title }}</h5>
            <p class="card-text text-muted small">{{ product.description|slice(0, 80) }}...</p>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <small class="text-muted">Per: <strong>{{ product.owner.name }}</strong></small>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 d-flex flex-column gap-2">
            <a href="{{ path('app_product_show', {slug: product.slug|default('fallback')}) }}" class="btn btn-outline-primary w-100">Veure detalls</a>
            {% if app.user and (app.user == product.owner) %}
                <div class="d-flex gap-2">
                    <a href="{{ path('app_product_edit', {slug: product.slug|default('fallback')}) }}" class="btn btn-warning flex-grow-1">Editar</a>
                    {{ include('product/_delete_form.html.twig') }}
                </div>
            {% endif %}
        </div>
    </div>
</div>
