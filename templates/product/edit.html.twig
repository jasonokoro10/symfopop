{% extends 'base.html.twig' %}

{% block title %}Editar producte{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning">
                    <h2 class="h4 mb-0">Editar producte: {{ product.title }}</h2>
                </div>
                <div class="card-body">
                    {{ include('product/_form.html.twig', {'button_label': 'Actualitzar producte'}) }}
                </div>
                <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_product_index') }}" class="btn btn-link">Tornar al llistat</a>
                    {{ include('product/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
