{% extends 'base.html.twig' %}

{% block title %}Catàleg - SymfoPop{% endblock %}

{% block body %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="mb-0">{{ is_my_list|default(false) ? 'Els meus productes' : 'Catàleg' }}</h1>
            {% if search_term|default(null) %}
                <p class="text-muted">Resultats per a: <strong>"{{ search_term }}"</strong></p>
            {% endif %}
        </div>
        
        <div class="d-flex gap-2">
            <form action="{{ path('app_product_index') }}" method="get" class="d-flex">
                <div class="input-group">
                    <input type="text" name="q" class="form-control" placeholder="Cerca producte..." value="{{ search_term|default('') }}">
                    <button class="btn btn-primary" type="submit">🔍</button>
                    {% if search_term|default(null) %}
                        <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary">X</a>
                    {% endif %}
                </div>
            </form>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_product_new') }}" class="btn btn-success ms-md-3 text-nowrap">+ Publicar producte</a>
            {% endif %}
        </div>
    </div>

    <div class="row">
        {% for product in products %}
            {{ include('product/_card.html.twig', {product: product}) }}
        {% else %}
            <div class="col-12 text-center py-5">
                <h3>No s'han trobat productes</h3>
                <p>Prova amb una altra cerca o publica el teu ara.</p>
                {% if app.user %}
                    <a href="{{ path('app_product_new') }}" class="btn btn-primary mt-3">Publicar un producte</a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endblock %}
