<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SymfoPop{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">📘 SymfoPop</a>
                <div class="navbar-nav">
                    <a class="nav-link" href="{{ path('app_product_index') }}">Productes</a>
                    {% if app.user %}
                        <a class="nav-link" href="{{ path('app_my_products') }}">Els meus productes</a>
                    {% endif %}
                </div>
                <div class="navbar-nav ms-auto">
                    {% if app.user %}
                        <span class="navbar-text me-3 text-white">Hola, {{ app.user.name }}</span>
                        <a class="nav-link btn btn-outline-danger btn-sm text-white" href="{{ path('app_logout') }}">Tancar sessió</a>
                    {% else %}
                        <a class="nav-link" href="{{ path('app_login') }}">Entrar</a>
                        <a class="nav-link btn btn-primary btn-sm text-white ms-2" href="{{ path('app_register') }}">Registrar-se</a>
                    {% endif %}
                </div>
            </div>
        </nav>

        <main class="container">
            {# Bloque para Mensajes Flash #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
